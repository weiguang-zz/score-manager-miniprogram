.form {
  padding-top: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--card-bg);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.6;
}

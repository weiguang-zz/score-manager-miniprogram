.filter-bar {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.filter-row:last-of-type {
  border-bottom: none;
}

.filter-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.filter-value {
  font-size: 28rpx;
  color: var(--primary);
}

.btn-query {
  width: 100%;
  height: 80rpx;
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-query[disabled] {
  opacity: 0.6;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 160rpx;
}

.record-card {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member-name {
  font-size: 30rpx;
  font-weight: 500;
}

.change {
  font-size: 32rpx;
  font-weight: bold;
}

.change.positive {
  color: var(--success);
}

.change.negative {
  color: var(--danger);
}

.reason {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-top: 8rpx;
}

.record-bottom {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.meta {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.room-tag {
  background: var(--primary-light);
  color: var(--primary);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.summary-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border-color);
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
}

.summary-value.positive {
  color: var(--success);
}

.summary-value.negative {
  color: var(--danger);
}

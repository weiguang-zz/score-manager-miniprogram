<navigation-bar title="修改密码" />

<view class="container">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">旧密码</text>
      <input
        class="form-input"
        type="text"
        password="{{true}}"
        placeholder="请输入旧密码"
        value="{{oldPassword}}"
        bindinput="onOldPasswordInput"
      />
    </view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input
        class="form-input"
        type="text"
        password="{{true}}"
        placeholder="请输入新密码（至少4位）"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
      />
    </view>
    <view class="form-item">
      <text class="form-label">确认密码</text>
      <input
        class="form-input"
        type="text"
        password="{{true}}"
        placeholder="请再次输入新密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>
  </view>

  <button class="btn btn-primary" bindtap="handleSubmit" disabled="{{loading}}">
    {{loading ? '提交中...' : '确认修改'}}
  </button>
</view>

<navigation-bar title="直播间管理" />

<view class="container">
  <!-- 添加直播间 -->
  <view class="add-bar">
    <input
      class="add-input"
      placeholder="输入直播间名称"
      value="{{newName}}"
      bindinput="onNewNameInput"
      confirm-type="done"
      bindconfirm="handleAdd"
    />
    <button class="btn-add" bindtap="handleAdd">添加</button>
  </view>

  <!-- 直播间列表 -->
  <view wx:if="{{loading && rooms.length === 0}}" class="empty">
    <text>加载中...</text>
  </view>
  <view wx:elif="{{rooms.length === 0}}" class="empty">
    <text class="empty-text">暂无直播间</text>
  </view>
  <view wx:else class="room-list">
    <view wx:for="{{rooms}}" wx:key="id" class="room-card">
      <!-- 编辑模式 -->
      <view wx:if="{{editingId === item.id}}" class="room-edit">
        <input
          class="edit-input"
          value="{{editingName}}"
          bindinput="onEditNameInput"
          focus="{{true}}"
        />
        <view class="edit-actions">
          <text class="action-btn save" bindtap="handleSaveEdit">保存</text>
          <text class="action-btn cancel" bindtap="cancelEdit">取消</text>
        </view>
      </view>
      <!-- 展示模式 -->
      <view wx:else class="room-row">
        <text class="room-name">{{item.name}}</text>
        <view class="room-actions">
          <text class="action-btn edit" bindtap="startEdit" data-id="{{item.id}}" data-name="{{item.name}}">改名</text>
          <text class="action-btn delete" bindtap="handleDelete" data-id="{{item.id}}" data-name="{{item.name}}">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>

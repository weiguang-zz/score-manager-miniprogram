<navigation-bar title="积分管理" back="{{false}}">
  <view slot="right" class="nav-right">
    <text class="nav-btn" bindtap="handleLogout">退出</text>
  </view>
</navigation-bar>

<view class="container">
  <!-- 操作栏 -->
  <view class="action-bar">
    <button wx:if="{{canEdit}}" class="btn btn-primary" bindtap="goAddMember">+ 添加成员</button>
    <button class="btn btn-outline" bindtap="exportAll">导出全部</button>
  </view>

  <!-- 管理入口 -->
  <view wx:if="{{isAdmin}}" class="admin-bar">
    <view class="admin-link" bindtap="goRecordsQuery">记录查询</view>
    <view class="admin-link" bindtap="goRoomManage">直播间管理</view>
    <view class="admin-link" bindtap="goStaffManage">员工管理</view>
    <view class="admin-link" bindtap="goChangePassword">修改密码</view>
  </view>
  <view wx:elif="{{!isAdmin}}" class="admin-bar">
    <view class="admin-link" bindtap="goRecordsQuery">记录查询</view>
    <view class="admin-link" bindtap="goChangePassword">修改密码</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-icon">🔍</view>
    <input
      class="search-input"
      placeholder="搜索成员"
      value="{{keyword}}"
      bindinput="onSearchInput"
    />
    <view wx:if="{{keyword}}" class="search-clear" bindtap="onSearchClear">✕</view>
  </view>

  <!-- 成员列表 -->
  <view wx:if="{{loading && members.length === 0}}" class="empty">
    <text>加载中...</text>
  </view>
  <view wx:elif="{{members.length === 0}}" class="empty">
    <text class="empty-text">暂无成员</text>
    <text wx:if="{{canEdit}}" class="empty-sub">点击上方按钮添加成员</text>
  </view>
  <view wx:else class="member-list">
    <view
      wx:for="{{members}}"
      wx:key="id"
      class="member-card"
      bindtap="goMemberDetail"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
      data-score="{{item.current_score}}"
    >
      <view class="member-info">
        <view class="avatar">{{item.name[0]}}</view>
        <text class="member-name">{{item.name}}</text>
      </view>
      <view class="score-area">
        <text class="score {{item.current_score >= 0 ? 'positive' : 'negative'}}">
          {{item.current_score}}
        </text>
        <text class="score-label">积分</text>
      </view>
    </view>
  </view>
</view>

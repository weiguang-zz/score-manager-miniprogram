.nav-right {
  padding-right: 16rpx;
}

.nav-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn {
  flex: 1;
  height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-outline {
  background: var(--card-bg);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.admin-bar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.admin-link {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 0;
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 72rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 8rpx;
  flex-shrink: 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.empty-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-bg);
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
}

.member-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--primary-light);
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.member-name {
  font-size: 30rpx;
  font-weight: 500;
}

.score-area {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.score {
  font-size: 36rpx;
  font-weight: bold;
}

.score.positive {
  color: var(--success);
}

.score.negative {
  color: var(--danger);
}

.score-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

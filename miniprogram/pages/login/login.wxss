.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary);
}

.logo-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.form {
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--card-bg);
}

.btn-login {
  width: 100%;
  height: 88rpx;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-login[disabled] {
  opacity: 0.6;
}

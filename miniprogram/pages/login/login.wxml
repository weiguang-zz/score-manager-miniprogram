<navigation-bar title="登录" back="{{false}}" />
<view class="container">
  <view class="logo-area">
    <text class="logo-text">积分管理</text>
    <text class="logo-sub">Score Manager</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">用户名</text>
      <input
        class="input"
        placeholder="请输入用户名"
        value="{{username}}"
        bindinput="onUsernameInput"
      />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input
        class="input"
        type="password"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>
    <button
      class="btn-login"
      bindtap="handleLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      登录
    </button>
  </view>
</view>

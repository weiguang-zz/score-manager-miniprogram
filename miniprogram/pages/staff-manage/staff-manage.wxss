.form-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.form-item {
  padding: 16rpx 0;
}

.form-item + .form-item {
  border-top: 1rpx solid var(--border-color);
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  font-size: 30rpx;
  height: 72rpx;
}

.picker-value {
  font-size: 30rpx;
  height: 72rpx;
  line-height: 72rpx;
  color: var(--text-primary);
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 20rpx;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.staff-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.staff-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-bg);
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
}

.staff-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.staff-name {
  font-size: 30rpx;
  font-weight: 500;
}

.staff-role {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.staff-actions {
  display: flex;
  gap: 24rpx;
}

.action-link {
  font-size: 26rpx;
  color: var(--primary);
}

.action-link.danger {
  color: var(--danger);
}
